   <string notr="true">QPushButton {
min-width: 32px;
min-height: 32px;
max-width: 32px;
max-height: 32px;
padding: 4px;
border: 6px solid gray;
}

#btnIcon{
qproperty-icon: url(:/setting.png);
qproperty-iconSize: 32px 32px;
}

#btnIcon_2{
qproperty-icon: url(:/setting.svg);
qproperty-iconSize: 32px 32px;
}

#btnImage{
image: url(:/setting.png);
}

#btnImage_2{
image: url(:/setting.svg);
}

#btnBgImage{
background-image: url(:/setting.png);
background-repeat: no-repeat;
background-position: center;
}

#btnBgImage_2{
background-image: url(:/setting.svg);
background-repeat: no-repeat;
background-position: center;
}

#btnBorderImage{
border-image: url(:/setting.png) 0 stretch stretch;
border: none;
padding: 0;
}

#btnBorderImage_2{
border-image: url(:/setting.svg) 0 stretch stretch;
border: none;
padding: 0;
}</string>
